{
  "name": "sonos-http-api",
  "version": "2.2.4",
  "type": "module",
  "description": "A simple node app for controlling a Sonos system with basic HTTP requests",
  "scripts": {
    "start": "node server.js",
    "build": "tsc",
    "lint": "eslint lib/ server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "author": "Jimmy Shimizu <jimmy@shimizu.se>",
  "repository": {
    "type": "git",
    "url": "https://github.com/TMA84/node-sonos-http-api.git"
  },
  "dependencies": {
    "@aws-sdk/client-polly": "^3.1041.0",
    "basic-auth": "~1.1.0",
    "elevenlabs-node": "2.0.1",
    "fuse.js": "^6.4.1",
    "html-entities": "^2.6.0",
    "json5": "^2.0.0",
    "mime": "^4.0.0",
    "music-metadata": "^11.12.3",
    "serve-static": "^1.15.0",
    "sonos-discovery": "file:./packages/sonos-discovery",
    "wav-file-info": "0.0.8"
  },
  "engines": {
    "node": ">=18"
  },
  "main": "lib/sonos-http-api.js",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/basic-auth": "^1.1.8",
    "@types/js-yaml": "^4.0.9",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@types/serve-static": "^2.2.0",
    "eslint": "^9.39.4",
    "fast-check": "^4.7.0",
    "js-yaml": "^4.1.1",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
